		<record id="purchase_order_form_currency_inv" model="ir.ui.view">
        <field name="name">purchase.order.form.currency</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- En Odoo 19 no existe action_create_invoice en el form.
                 Insertamos nuestro botón después del último botón del header -->
            <xpath expr="//button[@name='button_unlock']" position="after">
                <button name="%(l10n_ar_purchase.action_view_purchase_advance_invoice)d"
                    string="Crear Factura"
                    type="action"
                    class="btn-primary"
                    groups="purchase.group_purchase_manager"
                    invisible="invoice_status != 'to invoice' or state not in ('purchase',)"/>
            </xpath>
        </field>
    </record>
